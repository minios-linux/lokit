#: internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/yaml/properties/flutter/js-kv projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For index-source targets (source object with index, records_path, key_field,\n"
"fields): creates per-record translation files from the index file.\n"
"\n"
"For android/desktop/polkit projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      format: gettext                # Target format (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... format-specific options\n"
"\n"
"TARGET FORMATS\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — flat JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n (index source mode) — per-record JSON translations from one source index\n"
"    dir: web/public/data/recipe-translations\n"
"    pattern: \"{lang}/{id}.json\"      # Must include {id}\n"
"    source:\n"
"      index: web/public/data/recipes.json\n"
"      records_path: \"$\"              # Supported: $ or $.field\n"
"      key_field: id\n"
"      fields: [name, description, longDescription]\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir for markdown trees (required)\n"
"    pattern: \"{lang}\"               # Optional language directory pattern (default: {lang})\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"  js-kv — JavaScript assignment key/value translations\n"
"    dir: translations                # JS files directory (required)\n"
"    pattern: \"{lang}.js\"             # Language file pattern (required)\n"
"\n"
"  desktop — freedesktop desktop entries (single file)\n"
"    dir: .                           # Directory with desktop file\n"
"    pattern: \"myapp.desktop\"         # Desktop file name\n"
"\n"
"  polkit — PolicyKit XML policy (single file)\n"
"    dir: .                           # Directory with policy file\n"
"    pattern: \"org.example.policy\"    # Policy file name\n"
"\n"
"COMMON OPTIONS (all target formats)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # JSON web application\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"
msgstr ""
"翻訳可能な文字列を抽出し、翻訳ファイルを作成・更新します。\n"
"\n"
"プロジェクトルートに lokit.yaml 設定ファイルが必要です。\n"
"\n"
"gettext プロジェクトでは、xgettext を実行して文字列を POT テンプレートに抽出し、\n"
"各言語の PO ファイルを作成または更新します。\n"
"\n"
"po4a プロジェクトでは、'po4a --no-translations' を実行してテンプレートを更新します。\n"
"\n"
"i18next/vue-i18n/yaml/properties/flutter/js-kv プロジェクトでは、翻訳が空の\n"
"不足している言語ファイルを作成します。\n"
"\n"
"index-source ターゲット（source オブジェクトに index, records_path, key_field,\n"
"fields を指定）では、インデックスファイルからレコードごとの翻訳ファイルを作成します。\n"
"\n"
"android/desktop/polkit プロジェクトでは初期化ステップは不要です。'lokit translate'\n"
"を直接使用してください。\n"
"\n"
"このコマンドは冪等です。複数回実行しても安全です。ファイル更新時も既存の\n"
"翻訳は保持されます。\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # ソース言語（デフォルト: en）\n"
"  languages: [ru, de, fr, es, ...]   # 対象言語\n"
"\n"
"  targets:\n"
"    - name: myproject                # 表示名\n"
"      format: gettext                # 対象フォーマット（以下参照）\n"
"      root: .                        # 作業ディレクトリ（デフォルト: .）\n"
"      # ... フォーマット固有のオプション\n"
"\n"
"TARGET FORMATS\n"
"\n"
"  gettext — ソースコード文字列の抽出（shell, python, C, Go など）\n"
"    dir: po                          # PO ファイルのディレクトリ（必須）\n"
"    pot: messages.pot                # POT テンプレートのファイル名（dir 内）\n"
"    sources: [src, scripts]          # スキャン対象ディレクトリ（デフォルト: root）\n"
"    keywords: [_, N_, gettext]       # xgettext のキーワード（デフォルト: 標準セット）\n"
"\n"
"  po4a — ドキュメント翻訳（man ページ、AsciiDoc など）\n"
"    config: po4a.cfg                 # po4a.cfg のパス（必須）\n"
"\n"
"  i18next — フラットな JSON 翻訳\n"
"    dir: public/translations         # JSON ファイルのディレクトリ（必須）\n"
"    pattern: \"{lang}.json\"           # 言語ファイルのパターン（必須）\n"
"\n"
"  vue-i18n — ネストされた JSON 翻訳\n"
"    dir: frontend/src/i18n           # JSON ファイルのディレクトリ（必須）\n"
"    pattern: \"{lang}.json\"           # 言語ファイルのパターン（必須）\n"
"\n"
"  vue-i18n (index source mode) — 1つのソースインデックスからレコードごとの JSON 翻訳\n"
"    dir: web/public/data/recipe-translations\n"
"    pattern: \"{lang}/{id}.json\"      # {id} を含める必要があります\n"
"    source:\n"
"      index: web/public/data/recipes.json\n"
"      records_path: \"$\"              # 対応: $ または $.field\n"
"      key_field: id\n"
"      fields: [name, description, longDescription]\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android の res/ ディレクトリ（必須）\n"
"\n"
"  yaml — YAML のキー/値翻訳\n"
"    dir: translations                # YAML ファイルのディレクトリ（必須）\n"
"    pattern: \"{lang}.yaml\"           # 言語ファイルのパターン（必須）\n"
"\n"
"  markdown — Markdown ドキュメント翻訳\n"
"    dir: translations                # Markdown ツリーのルートディレクトリ（必須）\n"
"    pattern: \"{lang}\"               # 言語ディレクトリのパターン（任意、デフォルト: {lang}）\n"
"\n"
"  properties — Java .properties 翻訳\n"
"    dir: translations                # .properties ファイルのディレクトリ（必須）\n"
"    pattern: \"{lang}.properties\"     # 言語ファイルのパターン（必須）\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB ファイルのディレクトリ（必須）\n"
"    pattern: \"app_{lang}.arb\"        # 言語ファイルのパターン（必須）\n"
"\n"
"  js-kv — JavaScript の代入によるキー/値翻訳\n"
"    dir: translations                # JS ファイルのディレクトリ（必須）\n"
"    pattern: \"{lang}.js\"             # 言語ファイルのパターン（必須）\n"
"\n"
"  desktop — freedesktop desktop エントリ（単一ファイル）\n"
"    dir: .                           # desktop ファイルのあるディレクトリ\n"
"    pattern: \"myapp.desktop\"         # desktop ファイル名\n"
"\n"
"  polkit — PolicyKit XML ポリシー（単一ファイル）\n"
"    dir: .                           # ポリシーファイルのあるディレクトリ\n"
"    pattern: \"org.example.policy\"    # ポリシーファイル名\n"
"\n"
"COMMON OPTIONS (all target formats)\n"
"\n"
"  languages: [ru, de]               # グローバルな言語リストを上書き\n"
"  prompt: \"Custom translation...\"   # AI 翻訳プロンプトを上書き\n"
"\n"
"EXAMPLES\n"
"\n"
"  # gettext を使うシェルスクリプト\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # ラッパー関数を使う Go プロジェクト\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # ドキュメント + コード\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # JSON Web アプリケーション\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter アプリケーション\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # .properties を使う Java アプリケーション\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"

