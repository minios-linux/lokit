#: internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/yaml/properties/flutter/js-kv projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown/desktop/polkit projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      format: gettext                # Target format (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... format-specific options\n"
"\n"
"TARGET FORMATS\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — flat JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"  js-kv — JavaScript assignment key/value translations\n"
"    dir: translations                # JS files directory (required)\n"
"    pattern: \"{lang}.js\"             # Language file pattern (required)\n"
"\n"
"  desktop — freedesktop desktop entries (single file)\n"
"    dir: .                           # Directory with desktop file\n"
"    pattern: \"myapp.desktop\"         # Desktop file name\n"
"\n"
"  polkit — PolicyKit XML policy (single file)\n"
"    dir: .                           # Directory with policy file\n"
"    pattern: \"org.example.policy\"    # Policy file name\n"
"\n"
"COMMON OPTIONS (all target formats)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # JSON web application\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"
msgstr ""
"Extrae cadenas traducibles y crea/actualiza archivos de traducción.\n"
"\n"
"Requiere un archivo de configuración lokit.yaml en la raíz del proyecto.\n"
"\n"
"Para proyectos gettext: ejecuta xgettext para extraer cadenas a una plantilla POT,\n"
"luego crea o actualiza archivos PO para cada idioma.\n"
"\n"
"Para proyectos po4a: ejecuta 'po4a --no-translations' para actualizar plantillas.\n"
"\n"
"Para proyectos i18next/vue-i18n/yaml/properties/flutter/js-kv: crea archivos de idioma\n"
"faltantes con traducciones vacías.\n"
"\n"
"Para proyectos android/markdown/desktop/polkit: no se requiere paso de init — usa 'lokit translate'\n"
"directamente.\n"
"\n"
"Este comando es idempotente — es seguro ejecutarlo varias veces. Las traducciones existentes\n"
"se conservan al actualizar archivos.\n"
"\n"
"FORMATO DE CONFIGURACIÓN (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Idioma fuente (por defecto: en)\n"
"  languages: [ru, de, fr, es, ...]   # Idiomas de destino\n"
"\n"
"  targets:\n"
"    - name: myproject                # Nombre de visualización\n"
"      format: gettext                # Formato de destino (ver abajo)\n"
"      root: .                        # Directorio de trabajo (por defecto: .)\n"
"      # ... opciones específicas de formato\n"
"\n"
"FORMATOS DE DESTINO\n"
"\n"
"  gettext — Extracción de cadenas del código fuente (shell, python, C, Go, etc.)\n"
"    dir: po                          # Directorio de archivos PO (requerido)\n"
"    pot: messages.pot                # Nombre de archivo POT (dentro de dir)\n"
"    sources: [src, scripts]          # Directorios a escanear (por defecto: root)\n"
"    keywords: [_, N_, gettext]       # Palabras clave de xgettext (por defecto: conjunto estándar)\n"
"\n"
"  po4a — Traducción de documentación (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Ruta a po4a.cfg (requerido)\n"
"\n"
"  i18next — Traducciones JSON planas\n"
"    dir: public/translations         # Directorio de archivos JSON (requerido)\n"
"    pattern: \"{lang}.json\"           # Patrón de archivo de idioma (requerido)\n"
"\n"
"  vue-i18n — Traducciones JSON anidadas\n"
"    dir: frontend/src/i18n           # Directorio de archivos JSON (requerido)\n"
"    pattern: \"{lang}.json\"           # Patrón de archivo de idioma (requerido)\n"
"\n"
"  android — strings.xml de Android\n"
"    dir: app/src/main/res            # Directorio res/ de Android (requerido)\n"
"\n"
"  yaml — Traducciones YAML clave/valor\n"
"    dir: translations                # Directorio de archivos YAML (requerido)\n"
"    pattern: \"{lang}.yaml\"           # Patrón de archivo de idioma (requerido)\n"
"\n"
"  markdown — Traducción de documentos Markdown\n"
"    dir: translations                # Directorio raíz; archivos en translations/LANG/ (requerido)\n"
"\n"
"  properties — Traducciones Java .properties\n"
"    dir: translations                # Directorio de archivos .properties (requerido)\n"
"    pattern: \"{lang}.properties\"     # Patrón de archivo de idioma (requerido)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Directorio de archivos ARB (requerido)\n"
"    pattern: \"app_{lang}.arb\"        # Patrón de archivo de idioma (requerido)\n"
"\n"
"  js-kv — Traducciones clave/valor en JavaScript\n"
"    dir: translations                # Directorio de archivos JS (requerido)\n"
"    pattern: \"{lang}.js\"             # Patrón de archivo de idioma (requerido)\n"
"\n"
"  desktop — Entradas desktop de freedesktop (archivo único)\n"
"    dir: .                           # Directorio con el archivo desktop\n"
"    pattern: \"myapp.desktop\"         # Nombre del archivo desktop\n"
"\n"
"  polkit — Política XML de PolicyKit (archivo único)\n"
"    dir: .                           # Directorio con el archivo de política\n"
"    pattern: \"org.example.policy\"    # Nombre del archivo de política\n"
"\n"
"OPCIONES COMUNES (todos los formatos de destino)\n"
"\n"
"  languages: [ru, de]               # Sobrescribe la lista global de idiomas\n"
"  prompt: \"Traducción personalizada...\"   # Sobrescribe el prompt de traducción IA\n"
"\n"
"EJEMPLOS\n"
"\n"
"  # Scripts de shell con gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Proyecto Go con funciones wrapper\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentación + código\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # Aplicación web JSON\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Aplicación Flutter\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Aplicación Java con .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"

