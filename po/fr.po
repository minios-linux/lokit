#: /home/live/opencode/fb/lokit/internal/cli/init.go:23
msgid "Prepare translation files (extract strings, create/update PO)"
msgstr ""
"Extraction des chaînes traduisibles et création/mise à jour des fichiers de traduction.\n"
"\n"
"Nécessite un fichier de configuration lokit.yaml à la racine du projet.\n"
"\n"
"Pour les projets gettext : exécute xgettext pour extraire les chaînes dans un modèle POT,\n"
"puis crée ou met à jour les fichiers PO pour chaque langue.\n"
"\n"
"Pour les projets po4a : exécute 'po4a --no-translations' pour mettre à jour les modèles.\n"
"\n"
"Pour i18next/vue-i18n/json/yaml/properties/flutter : crée les fichiers de langue manquants\n"
"avec des traductions vides.\n"
"\n"
"Pour android/markdown : pas d'étape d'init — utilisez directement 'lokit translate'.\n"
"\n"
"Cette commande est idempotente — peut être relancée sans risque. Les traductions existantes\n"
"sont conservées lors de la mise à jour des fichiers.\n"
"\n"
"FORMAT CONFIG (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Langue source (défaut : en)\n"
"  languages: [ru, de, fr, es, ...]   # Langues cibles\n"
"\n"
"  targets:\n"
"    - name: myproject                # Nom d'affichage\n"
"      type: gettext                  # Type de cible (voir ci-dessous)\n"
"      root: .                        # Dossier de travail (défaut : .)\n"
"      # ... options spécifiques au type\n"
"\n"
"TYPES DE CIBLE\n"
"\n"
"  gettext — Extraction de chaînes du code source (shell, python, C, Go, etc.)\n"
"    dir: po                          # Dossier des fichiers PO (obligatoire)\n"
"    pot: messages.pot                # Nom du modèle POT (dans dir)\n"
"    sources: [src, scripts]          # Dossiers à scanner (défaut : root)\n"
"    keywords: [_, N_, gettext]       # Mots-clés xgettext (défaut : standard)\n"
"\n"
"  po4a — Traduction de documentation (pages de manuel, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Chemin vers po4a.cfg (obligatoire)\n"
"\n"
"  i18next — Traductions JSON i18next\n"
"    dir: public/translations         # Dossier JSON (obligatoire)\n"
"    pattern: \"{lang}.json\"           # Motif des fichiers langue (obligatoire)\n"
"\n"
"  vue-i18n — Traductions JSON imbriquées vue-i18n\n"
"    dir: frontend/src/i18n           # Dossier JSON (obligatoire)\n"
"    pattern: \"{lang}.json\"           # Motif des fichiers langue (obligatoire)\n"
"\n"
"  json — Traductions JSON simples { \"key\": \"value\" }\n"
"    dir: translations                # Dossier JSON (obligatoire)\n"
"    pattern: \"{lang}.json\"           # Motif des fichiers langue (obligatoire)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Dossier res/ Android (obligatoire)\n"
"\n"
"  yaml — Traductions clé/valeur YAML\n"
"    dir: translations                # Dossier YAML (obligatoire)\n"
"    pattern: \"{lang}.yaml\"           # Motif des fichiers langue (obligatoire)\n"
"\n"
"  markdown — Traduction de documents Markdown\n"
"    dir: translations                # Dossier racine ; fichiers dans translations/LANG/ (obligatoire)\n"
"\n"
"  properties — Traductions Java .properties\n"
"    dir: translations                # Dossier .properties (obligatoire)\n"
"    pattern: \"{lang}.properties\"     # Motif des fichiers langue (obligatoire)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Dossier ARB (obligatoire)\n"
"    pattern: \"app_{lang}.arb\"        # Motif des fichiers langue (obligatoire)\n"
"\n"
"OPTIONS COMMUNES (tous types de cibles)\n"
"\n"
"  languages: [ru, de]               # Liste de langues spécifique à la cible\n"
"  prompt: \"Traduction personnalisée...\"   # Prompt IA personnalisé\n"
"\n"
"EXEMPLES\n"
"\n"
"  # Scripts shell avec gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Projet Go avec wrappers\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # Application web i18next\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Application Flutter\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Application Java avec .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"

#: /home/live/opencode/fb/lokit/internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/json/yaml/properties/flutter projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      type: gettext                  # Target type (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... type-specific options\n"
"\n"
"TARGET TYPES\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — i18next JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — vue-i18n nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  json — Simple JSON translations { \"key\": \"value\" }\n"
"    dir: translations                # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"COMMON OPTIONS (all target types)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # i18next web application\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"
msgstr "Langues à initialiser (séparées par des virgules, défaut : toutes de la config)"

