#: internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/yaml/properties/flutter/js-kv projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown/desktop/polkit projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      format: gettext                # Target format (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... format-specific options\n"
"\n"
"TARGET FORMATS\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — flat JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"  js-kv — JavaScript assignment key/value translations\n"
"    dir: translations                # JS files directory (required)\n"
"    pattern: \"{lang}.js\"             # Language file pattern (required)\n"
"\n"
"  desktop — freedesktop desktop entries (single file)\n"
"    dir: .                           # Directory with desktop file\n"
"    pattern: \"myapp.desktop\"         # Desktop file name\n"
"\n"
"  polkit — PolicyKit XML policy (single file)\n"
"    dir: .                           # Directory with policy file\n"
"    pattern: \"org.example.policy\"    # Policy file name\n"
"\n"
"COMMON OPTIONS (all target formats)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # JSON web application\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"
msgstr ""
"Extraire les chaînes traduisibles et créer/mettre à jour les fichiers de traduction.\n"
"\n"
"Nécessite un fichier de configuration lokit.yaml à la racine du projet.\n"
"\n"
"Pour les projets gettext : exécute xgettext pour extraire les chaînes dans un modèle POT,\n"
"puis crée ou met à jour les fichiers PO pour chaque langue.\n"
"\n"
"Pour les projets po4a : exécute 'po4a --no-translations' pour mettre à jour les modèles.\n"
"\n"
"Pour les projets i18next/vue-i18n/yaml/properties/flutter/js-kv : crée les fichiers de langue\n"
"manquants avec des traductions vides.\n"
"\n"
"Pour les projets android/markdown/desktop/polkit : aucune étape d'init requise — utilisez directement 'lokit translate'.\n"
"\n"
"Cette commande est idempotente — vous pouvez l'exécuter plusieurs fois sans risque. Les traductions existantes sont conservées lors de la mise à jour des fichiers.\n"
"\n"
"FORMAT DE CONFIGURATION (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Langue source (défaut : en)\n"
"  languages: [ru, de, fr, es, ...]   # Langues cibles\n"
"\n"
"  targets:\n"
"    - name: myproject                # Nom d'affichage\n"
"      format: gettext                # Format cible (voir ci-dessous)\n"
"      root: .                        # Répertoire de travail (défaut : .)\n"
"      # ... options spécifiques au format\n"
"\n"
"FORMATS CIBLES\n"
"\n"
"  gettext — Extraction de chaînes du code source (shell, python, C, Go, etc.)\n"
"    dir: po                          # Répertoire des fichiers PO (obligatoire)\n"
"    pot: messages.pot                # Nom du modèle POT (dans dir)\n"
"    sources: [src, scripts]          # Répertoires à analyser (défaut : root)\n"
"    keywords: [_, N_, gettext]       # Mots-clés xgettext (défaut : standard)\n"
"\n"
"  po4a — Traduction de documentation (manuels, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Chemin vers po4a.cfg (obligatoire)\n"
"\n"
"  i18next — Traductions JSON plates\n"
"    dir: public/translations         # Répertoire des fichiers JSON (obligatoire)\n"
"    pattern: \"{lang}.json\"           # Modèle de nom de fichier langue (obligatoire)\n"
"\n"
"  vue-i18n — Traductions JSON imbriquées\n"
"    dir: frontend/src/i18n           # Répertoire des fichiers JSON (obligatoire)\n"
"    pattern: \"{lang}.json\"           # Modèle de nom de fichier langue (obligatoire)\n"
"\n"
"  android — strings.xml Android\n"
"    dir: app/src/main/res            # Répertoire res/ Android (obligatoire)\n"
"\n"
"  yaml — Traductions YAML clé/valeur\n"
"    dir: translations                # Répertoire des fichiers YAML (obligatoire)\n"
"    pattern: \"{lang}.yaml\"           # Modèle de nom de fichier langue (obligatoire)\n"
"\n"
"  markdown — Traduction de documents Markdown\n"
"    dir: translations                # Répertoire racine ; fichiers dans translations/LANG/ (obligatoire)\n"
"\n"
"  properties — Traductions Java .properties\n"
"    dir: translations                # Répertoire des fichiers .properties (obligatoire)\n"
"    pattern: \"{lang}.properties\"     # Modèle de nom de fichier langue (obligatoire)\n"
"\n"
"  flutter — ARB Flutter (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Répertoire des fichiers ARB (obligatoire)\n"
"    pattern: \"app_{lang}.arb\"        # Modèle de nom de fichier langue (obligatoire)\n"
"\n"
"  js-kv — Traductions JavaScript clé/valeur\n"
"    dir: translations                # Répertoire des fichiers JS (obligatoire)\n"
"    pattern: \"{lang}.js\"             # Modèle de nom de fichier langue (obligatoire)\n"
"\n"
"  desktop — Entrées desktop freedesktop (fichier unique)\n"
"    dir: .                           # Répertoire contenant le fichier desktop\n"
"    pattern: \"myapp.desktop\"         # Nom du fichier desktop\n"
"\n"
"  polkit — Politique XML PolicyKit (fichier unique)\n"
"    dir: .                           # Répertoire contenant le fichier de politique\n"
"    pattern: \"org.example.policy\"    # Nom du fichier de politique\n"
"\n"
"OPTIONS COMMUNES (tous les formats cibles)\n"
"\n"
"  languages: [ru, de]               # Remplace la liste globale des langues\n"
"  prompt: \"Traduction personnalisée...\"   # Remplace le prompt de traduction IA\n"
"\n"
"EXEMPLES\n"
"\n"
"  # Scripts shell avec gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Projet Go avec fonctions wrapper\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # Application web JSON\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Application Flutter\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Application Java avec .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"

