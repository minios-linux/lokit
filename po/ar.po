#: /home/live/opencode/fb/lokit/internal/cli/root.go:65
msgid "Invalid locked_pattern %q: %v"
msgstr ""
"استخراج النصوص القابلة للترجمة وإنشاء/تحديث ملفات الترجمة.\n"
"\n"
"يتطلب ملف إعداد lokit.yaml في جذر المشروع.\n"
"\n"
"لمشاريع gettext: تشغيل xgettext لاستخراج النصوص إلى قالب POT،\n"
"ثم إنشاء أو تحديث ملفات PO لكل لغة.\n"
"\n"
"لمشاريع po4a: تشغيل 'po4a --no-translations' لتحديث القوالب.\n"
"\n"
"لمشاريع i18next/vue-i18n/json/yaml/properties/flutter: إنشاء ملفات اللغات المفقودة بترجمات فارغة.\n"
"\n"
"لمشاريع android/markdown: لا حاجة لخطوة تهيئة — استخدم 'lokit translate'\n"
"مباشرة.\n"
"\n"
"هذا الأمر آمن للتكرار — يمكنك تشغيله عدة مرات. الترجمات الحالية محفوظة عند تحديث الملفات.\n"
"\n"
"صيغة الإعداد (lokit.yaml)\n"
"\n"
"  source_lang: en                    # لغة المصدر (الافتراضي: en)\n"
"  languages: [ru, de, fr, es, ...]   # اللغات المستهدفة\n"
"\n"
"  targets:\n"
"    - name: myproject                # اسم العرض\n"
"      type: gettext                  # نوع الهدف (انظر أدناه)\n"
"      root: .                        # مجلد العمل (الافتراضي: .)\n"
"      # ... خيارات حسب النوع\n"
"\n"
"أنواع الأهداف\n"
"\n"
"  gettext — استخراج نصوص الشيفرة المصدرية (shell، python، C، Go، إلخ)\n"
"    dir: po                          # مجلد ملفات PO (مطلوب)\n"
"    pot: messages.pot                # اسم قالب POT (داخل المجلد)\n"
"    sources: [src, scripts]          # مجلدات الفحص (الافتراضي: root)\n"
"    keywords: [_, N_, gettext]       # كلمات xgettext (الافتراضي: مجموعة قياسية)\n"
"\n"
"  po4a — ترجمة الوثائق (صفحات man، AsciiDoc، إلخ)\n"
"    config: po4a.cfg                 # مسار po4a.cfg (مطلوب)\n"
"\n"
"  i18next — ترجمات i18next JSON\n"
"    dir: public/translations         # مجلد ملفات JSON (مطلوب)\n"
"    pattern: \"{lang}.json\"           # نمط ملف اللغة (مطلوب)\n"
"\n"
"  vue-i18n — ترجمات vue-i18n JSON متداخلة\n"
"    dir: frontend/src/i18n           # مجلد ملفات JSON (مطلوب)\n"
"    pattern: \"{lang}.json\"           # نمط ملف اللغة (مطلوب)\n"
"\n"
"  json — ترجمات JSON بسيطة { \"key\": \"value\" }\n"
"    dir: translations                # مجلد ملفات JSON (مطلوب)\n"
"    pattern: \"{lang}.json\"           # نمط ملف اللغة (مطلوب)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # مجلد res/ الخاص بـ Android (مطلوب)\n"
"\n"
"  yaml — ترجمات YAML مفتاح/قيمة\n"
"    dir: translations                # مجلد ملفات YAML (مطلوب)\n"
"    pattern: \"{lang}.yaml\"           # نمط ملف اللغة (مطلوب)\n"
"\n"
"  markdown — ترجمة مستندات Markdown\n"
"    dir: translations                # المجلد الجذري؛ الملفات في translations/LANG/ (مطلوب)\n"
"\n"
"  properties — ترجمات Java .properties\n"
"    dir: translations                # مجلد ملفات .properties (مطلوب)\n"
"    pattern: \"{lang}.properties\"     # نمط ملف اللغة (مطلوب)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # مجلد ملفات ARB (مطلوب)\n"
"    pattern: \"app_{lang}.arb\"        # نمط ملف اللغة (مطلوب)\n"
"\n"
"خيارات عامة (جميع الأنواع)\n"
"\n"
"  languages: [ru, de]               # تجاوز قائمة اللغات العامة\n"
"  prompt: \"ترجمة مخصصة...\"           # تجاوز prompt الترجمة بالذكاء الاصطناعي\n"
"\n"
"أمثلة\n"
"\n"
"  # سكربتات shell مع gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # مشروع Go مع دوال مغلفة\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # وثائق + كود\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # تطبيق ويب i18next\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # تطبيق Flutter\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # تطبيق Java مع .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"

