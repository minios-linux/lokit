#: internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/json/yaml/properties/flutter projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      type: gettext                  # Target type (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... type-specific options\n"
"\n"
"TARGET TYPES\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — i18next JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — vue-i18n nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  json — Simple JSON translations { \"key\": \"value\" }\n"
"    dir: translations                # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"COMMON OPTIONS (all target types)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # i18next web application\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"
msgstr ""
"Извлечь переводимые строки и создать/обновить файлы переводов.\n"
"\n"
"Требуется файл конфигурации lokit.yaml в корне проекта.\n"
"\n"
"Для проектов на gettext: запускается xgettext для извлечения строк в POT-шаблон,\n"
"после чего создаются или обновляются PO-файлы для каждого языка.\n"
"\n"
"Для проектов po4a: запускается 'po4a --no-translations' для обновления шаблонов.\n"
"\n"
"Для проектов i18next/vue-i18n/json/yaml/properties/flutter: создаются отсутствующие\n"
"файлы языков с пустыми переводами.\n"
"\n"
"Для проектов android/markdown шаг init не требуется — используйте прямо 'lokit translate'.\n"
"\n"
"Команда идемпотентна — безопасно запускать несколько раз. Существующие\n"
"переводы сохраняются при обновлении файлов.\n"
"\n"
"ФОРМАТ КОНФИГУРАЦИИ (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Язык-источник (по умолчанию: en)\n"
"  languages: [ru, de, fr, es, ...]   # Целевые языки\n"
"\n"
"  targets:\n"
"    - name: myproject                # Отображаемое имя\n"
"      type: gettext                  # Тип цели (см. ниже)\n"
"      root: .                        # Рабочая директория (по умолчанию: .)\n"
"      # ... опции, специфичные для типа\n"
"\n"
"ТИПЫ ЦЕЛЕЙ\n"
"\n"
"  gettext — извлечение строк из исходного кода (shell, python, C, Go и др.)\n"
"    dir: po                          # Каталог PO-файлов (обязательно)\n"
"    pot: messages.pot                # Имя POT-шаблона (внутри dir)\n"
"    sources: [src, scripts]          # Директории для сканирования (по умолчанию: root)\n"
"    keywords: [_, N_, gettext]       # Ключевые слова xgettext (по умолчанию: стандартный набор)\n"
"\n"
"  po4a — перевод документации (man, AsciiDoc и др.)\n"
"    config: po4a.cfg                 # Путь к po4a.cfg (обязательно)\n"
"\n"
"  i18next — i18next JSON-переводы\n"
"    dir: public/translations         # Каталог JSON-файлов (обязательно)\n"
"    pattern: \"{lang}.json\"           # Шаблон имени файла языка (обязательно)\n"
"\n"
"  vue-i18n — вложенные JSON-переводы для vue-i18n\n"
"    dir: frontend/src/i18n           # Каталог JSON-файлов (обязательно)\n"
"    pattern: \"{lang}.json\"           # Шаблон имени файла языка (обязательно)\n"
"\n"
"  json — простые JSON-переводы { \"key\": \"value\" }\n"
"    dir: translations                # Каталог JSON-файлов (обязательно)\n"
"    pattern: \"{lang}.json\"           # Шаблон имени файла языка (обязательно)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Каталог res/ Android (обязательно)\n"
"\n"
"  yaml — YAML key/value переводы\n"
"    dir: translations                # Каталог YAML-файлов (обязательно)\n"
"    pattern: \"{lang}.yaml\"           # Шаблон имени файла языка (обязательно)\n"
"\n"
"  markdown — перевод Markdown-документов\n"
"    dir: translations                # Корень; файлы в translations/LANG/ (обязательно)\n"
"\n"
"  properties — Java .properties переводы\n"
"    dir: translations                # Каталог .properties (обязательно)\n"
"    pattern: \"{lang}.properties\"     # Шаблон имени файла языка (обязательно)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Каталог ARB-файлов (обязательно)\n"
"    pattern: \"app_{lang}.arb\"        # Шаблон имени файла языка (обязательно)\n"
"\n"
"ОБЩИЕ ОПЦИИ (для всех типов целей)\n"
"\n"
"  languages: [ru, de]               # Переопределить глобальный список языков\n"
"  prompt: \"Custom translation...\"   # Переопределить AI-prompt для переводов\n"
"\n"
"ПРИМЕРЫ\n"
"\n"
"  # Shell-скрипты с gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go-проект с обёртками\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Документация + код\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # i18next веб-приложение\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter-приложение\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java-приложение с .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"

