#: internal/cli/target_vuei18n.go:115
msgid "Vue i18n init: %d created, %d updated"
msgstr ""
"Estrai le stringhe traducibili e crea/aggiorna i file di traduzione.\n"
"\n"
"Richiede un file di configurazione lokit.yaml nella root del progetto.\n"
"\n"
"Per progetti gettext: esegue xgettext per estrarre le stringhe in un template POT,\n"
"poi crea o aggiorna i file PO per ogni lingua.\n"
"\n"
"Per progetti po4a: esegue 'po4a --no-translations' per aggiornare i template.\n"
"\n"
"Per progetti i18next/vue-i18n/json/yaml/properties/flutter: crea i file lingua mancanti\n"
"con traduzioni vuote.\n"
"\n"
"Per progetti android/markdown: nessun passaggio di init necessario — usa direttamente 'lokit translate'.\n"
"\n"
"Questo comando è idempotente — sicuro da eseguire più volte. Le traduzioni esistenti vengono preservate durante l'aggiornamento dei file.\n"
"\n"
"FORMATO CONFIG (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Lingua sorgente (predefinito: en)\n"
"  languages: [ru, de, fr, es, ...]   # Lingue di destinazione\n"
"\n"
"  targets:\n"
"    - name: myproject                # Nome visualizzato\n"
"      type: gettext                  # Tipo di target (vedi sotto)\n"
"      root: .                        # Directory di lavoro (predefinito: .)\n"
"      # ... opzioni specifiche del tipo\n"
"\n"
"TIPI DI TARGET\n"
"\n"
"  gettext — Estrazione stringhe dal codice (shell, python, C, Go, ecc.)\n"
"    dir: po                          # Directory file PO (richiesta)\n"
"    pot: messages.pot                # Nome file template POT (dentro dir)\n"
"    sources: [src, scripts]          # Directory da scansionare (predefinito: root)\n"
"    keywords: [_, N_, gettext]       # Keyword xgettext (predefinito: set standard)\n"
"\n"
"  po4a — Traduzione documentazione (man page, AsciiDoc, ecc.)\n"
"    config: po4a.cfg                 # Percorso po4a.cfg (richiesto)\n"
"\n"
"  i18next — Traduzioni i18next JSON\n"
"    dir: public/translations         # Directory file JSON (richiesta)\n"
"    pattern: \"{lang}.json\"           # Pattern file lingua (richiesto)\n"
"\n"
"  vue-i18n — Traduzioni JSON annidate vue-i18n\n"
"    dir: frontend/src/i18n           # Directory file JSON (richiesta)\n"
"    pattern: \"{lang}.json\"           # Pattern file lingua (richiesto)\n"
"\n"
"  json — Traduzioni JSON semplici { \"key\": \"value\" }\n"
"    dir: translations                # Directory file JSON (richiesta)\n"
"    pattern: \"{lang}.json\"           # Pattern file lingua (richiesto)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Directory res/ Android (richiesta)\n"
"\n"
"  yaml — Traduzioni YAML chiave/valore\n"
"    dir: translations                # Directory file YAML (richiesta)\n"
"    pattern: \"{lang}.yaml\"           # Pattern file lingua (richiesto)\n"
"\n"
"  markdown — Traduzione documenti Markdown\n"
"    dir: translations                # Directory root; file in translations/LANG/ (richiesta)\n"
"\n"
"  properties — Traduzioni Java .properties\n"
"    dir: translations                # Directory file .properties (richiesta)\n"
"    pattern: \"{lang}.properties\"     # Pattern file lingua (richiesto)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Directory file ARB (richiesta)\n"
"    pattern: \"app_{lang}.arb\"        # Pattern file lingua (richiesto)\n"
"\n"
"OPZIONI COMUNI (tutti i tipi di target)\n"
"\n"
"  languages: [ru, de]               # Sovrascrive la lista lingue globale\n"
"  prompt: \"Traduzione personalizzata...\"   # Sovrascrive il prompt IA\n"
"\n"
"ESEMPI\n"
"\n"
"  # Script shell con gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Progetto Go con funzioni wrapper\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentazione + codice\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # Applicazione web i18next\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Applicazione Flutter\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Applicazione Java con .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"

