msgstr "Prepara i file di traduzione (estrae le stringhe, crea/aggiorna PO)"

#: internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/yaml/properties/flutter/js-kv projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For index-source targets (source object with index, records_path, key_field,\n"
"fields): creates per-record translation files from the index file.\n"
"\n"
"For android/desktop/polkit projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      format: gettext                # Target format (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... format-specific options\n"
"\n"
"TARGET FORMATS\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — flat JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n (index source mode) — per-record JSON translations from one source index\n"
"    dir: web/public/data/recipe-translations\n"
"    pattern: \"{lang}/{id}.json\"      # Must include {id}\n"
"    source:\n"
"      index: web/public/data/recipes.json\n"
"      records_path: \"$\"              # Supported: $ or $.field\n"
"      key_field: id\n"
"      fields: [name, description, longDescription]\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir for markdown trees (required)\n"
"    pattern: \"{lang}\"               # Optional language directory pattern (default: {lang})\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"  js-kv — JavaScript assignment key/value translations\n"
"    dir: translations                # JS files directory (required)\n"
"    pattern: \"{lang}.js\"             # Language file pattern (required)\n"
"\n"
"  desktop — freedesktop desktop entries (single file)\n"
"    dir: .                           # Directory with desktop file\n"
"    pattern: \"myapp.desktop\"         # Desktop file name\n"
"\n"
"  polkit — PolicyKit XML policy (single file)\n"
"    dir: .                           # Directory with policy file\n"
"    pattern: \"org.example.policy\"    # Policy file name\n"
"\n"
"COMMON OPTIONS (all target formats)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # JSON web application\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"
msgstr ""
"Estrai le stringhe traducibili e crea/aggiorna i file di traduzione.\n"
"\n"
"Richiede un file di configurazione lokit.yaml nella root del progetto.\n"
"\n"
"Per i progetti gettext: esegue xgettext per estrarre le stringhe in un template POT,\n"
"quindi crea o aggiorna i file PO per ciascuna lingua.\n"
"\n"
"Per i progetti po4a: esegue 'po4a --no-translations' per aggiornare i template.\n"
"\n"
"Per i progetti i18next/vue-i18n/yaml/properties/flutter/js-kv: crea i file di lingua\n"
"mancanti con traduzioni vuote.\n"
"\n"
"Per i target index-source (oggetto source con index, records_path, key_field,\n"
"fields): crea file di traduzione per ciascun record a partire dal file index.\n"
"\n"
"Per i progetti android/desktop/polkit: non è necessario alcuno step di inizializzazione — usa direttamente 'lokit translate'.\n"
"\n"
"Questo comando è idempotente: può essere eseguito più volte in sicurezza. Le traduzioni\n"
"esistenti vengono preservate durante l'aggiornamento dei file.\n"
"\n"
"FORMATO CONFIGURAZIONE (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Lingua sorgente (predefinita: en)\n"
"  languages: [ru, de, fr, es, ...]   # Lingue di destinazione\n"
"\n"
"  targets:\n"
"    - name: myproject                # Nome visualizzato\n"
"      format: gettext                # Formato di destinazione (vedi sotto)\n"
"      root: .                        # Directory di lavoro (predefinita: .)\n"
"      # ... opzioni specifiche del formato\n"
"\n"
"FORMATI DI DESTINAZIONE\n"
"\n"
"  gettext — Estrazione di stringhe dal codice sorgente (shell, python, C, Go, ecc.)\n"
"    dir: po                          # Directory dei file PO (obbligatoria)\n"
"    pot: messages.pot                # Nome del template POT (all'interno di dir)\n"
"    sources: [src, scripts]          # Directory da scansionare (predefinito: root)\n"
"    keywords: [_, N_, gettext]       # Keyword di xgettext (predefinito: set standard)\n"
"\n"
"  po4a — Traduzione di documentazione (man page, AsciiDoc, ecc.)\n"
"    config: po4a.cfg                 # Percorso di po4a.cfg (obbligatorio)\n"
"\n"
"  i18next — traduzioni JSON piatte\n"
"    dir: public/translations         # Directory dei file JSON (obbligatoria)\n"
"    pattern: \"{lang}.json\"           # Pattern del file lingua (obbligatorio)\n"
"\n"
"  vue-i18n — traduzioni JSON annidate\n"
"    dir: frontend/src/i18n           # Directory dei file JSON (obbligatoria)\n"
"    pattern: \"{lang}.json\"           # Pattern del file lingua (obbligatorio)\n"
"\n"
"  vue-i18n (modalità index source) — traduzioni JSON per record da un indice sorgente\n"
"    dir: web/public/data/recipe-translations\n"
"    pattern: \"{lang}/{id}.json\"      # Deve includere {id}\n"
"    source:\n"
"      index: web/public/data/recipes.json\n"
"      records_path: \"$\"              # Supportato: $ o $.field\n"
"      key_field: id\n"
"      fields: [name, description, longDescription]\n"
"\n"
"  android — strings.xml di Android\n"
"    dir: app/src/main/res            # Directory res/ di Android (obbligatoria)\n"
"\n"
"  yaml — traduzioni key/value in YAML\n"
"    dir: translations                # Directory dei file YAML (obbligatoria)\n"
"    pattern: \"{lang}.yaml\"           # Pattern del file lingua (obbligatorio)\n"
"\n"
"  markdown — traduzione di documenti Markdown\n"
"    dir: translations                # Directory root per alberi Markdown (obbligatoria)\n"
"    pattern: \"{lang}\"               # Pattern opzionale della directory lingua (predefinito: {lang})\n"
"\n"
"  properties — traduzioni Java .properties\n"
"    dir: translations                # Directory dei file .properties (obbligatoria)\n"
"    pattern: \"{lang}.properties\"     # Pattern del file lingua (obbligatorio)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Directory dei file ARB (obbligatoria)\n"
"    pattern: \"app_{lang}.arb\"        # Pattern del file lingua (obbligatorio)\n"
"\n"
"  js-kv — traduzioni key/value con assegnazioni JavaScript\n"
"    dir: translations                # Directory dei file JS (obbligatoria)\n"
"    pattern: \"{lang}.js\"             # Pattern del file lingua (obbligatorio)\n"
"\n"
"  desktop — voci desktop freedesktop (file singolo)\n"
"    dir: .                           # Directory con il file desktop\n"
"    pattern: \"myapp.desktop\"         # Nome del file desktop\n"
"\n"
"  polkit — policy XML PolicyKit (file singolo)\n"
"    dir: .                           # Directory con il file policy\n"
"    pattern: \"org.example.policy\"    # Nome del file policy\n"
"\n"
"OPZIONI COMUNI (tutti i formati di destinazione)\n"
"\n"
"  languages: [ru, de]               # Sostituisce l'elenco globale delle lingue\n"
"  prompt: \"Custom translation...\"   # Sostituisce il prompt di traduzione AI\n"
"\n"
"ESEMPI\n"
"\n"
"  # Script shell con gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Progetto Go con funzioni wrapper\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentazione + codice\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # Applicazione web JSON\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Applicazione Flutter\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Applicazione Java con .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"

