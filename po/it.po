#: internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/yaml/properties/flutter/js-kv projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown/desktop/polkit projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      format: gettext                # Target format (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... format-specific options\n"
"\n"
"TARGET FORMATS\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — flat JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"  js-kv — JavaScript assignment key/value translations\n"
"    dir: translations                # JS files directory (required)\n"
"    pattern: \"{lang}.js\"             # Language file pattern (required)\n"
"\n"
"  desktop — freedesktop desktop entries (single file)\n"
"    dir: .                           # Directory with desktop file\n"
"    pattern: \"myapp.desktop\"         # Desktop file name\n"
"\n"
"  polkit — PolicyKit XML policy (single file)\n"
"    dir: .                           # Directory with policy file\n"
"    pattern: \"org.example.policy\"    # Policy file name\n"
"\n"
"COMMON OPTIONS (all target formats)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # JSON web application\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"
msgstr ""
"Estrae le stringhe traducibili e crea/aggiorna i file di traduzione.\n"
"\n"
"Richiede un file di configurazione lokit.yaml nella root del progetto.\n"
"\n"
"Per progetti gettext: esegue xgettext per estrarre le stringhe in un template POT,\n"
"poi crea o aggiorna i file PO per ogni lingua.\n"
"\n"
"Per progetti po4a: esegue 'po4a --no-translations' per aggiornare i template.\n"
"\n"
"Per progetti i18next/vue-i18n/yaml/properties/flutter/js-kv: crea i file lingua mancanti\n"
"con traduzioni vuote.\n"
"\n"
"Per progetti android/markdown/desktop/polkit: non è necessario l'init — usa direttamente 'lokit translate'.\n"
"\n"
"Questo comando è idempotente — può essere eseguito più volte senza rischi. Le traduzioni\n"
"esistenti vengono mantenute durante l'aggiornamento dei file.\n"
"\n"
"FORMATO CONFIGURAZIONE (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Lingua sorgente (predefinito: en)\n"
"  languages: [ru, de, fr, es, ...]   # Lingue di destinazione\n"
"\n"
"  targets:\n"
"    - name: myproject                # Nome visualizzato\n"
"      format: gettext                # Formato di destinazione (vedi sotto)\n"
"      root: .                        # Directory di lavoro (predefinito: .)\n"
"      # ... opzioni specifiche del formato\n"
"\n"
"FORMATI DI DESTINAZIONE\n"
"\n"
"  gettext — Estrazione stringhe dal codice sorgente (shell, python, C, Go, ecc.)\n"
"    dir: po                          # Directory file PO (obbligatorio)\n"
"    pot: messages.pot                # Nome file template POT (all'interno di dir)\n"
"    sources: [src, scripts]          # Directory da scansionare (predefinito: root)\n"
"    keywords: [_, N_, gettext]       # Parole chiave xgettext (predefinito: set standard)\n"
"\n"
"  po4a — Traduzione documentazione (man page, AsciiDoc, ecc.)\n"
"    config: po4a.cfg                 # Percorso po4a.cfg (obbligatorio)\n"
"\n"
"  i18next — Traduzioni JSON flat\n"
"    dir: public/translations         # Directory file JSON (obbligatorio)\n"
"    pattern: \"{lang}.json\"           # Pattern file lingua (obbligatorio)\n"
"\n"
"  vue-i18n — Traduzioni JSON annidate\n"
"    dir: frontend/src/i18n           # Directory file JSON (obbligatorio)\n"
"    pattern: \"{lang}.json\"           # Pattern file lingua (obbligatorio)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Directory res/ Android (obbligatorio)\n"
"\n"
"  yaml — Traduzioni YAML key/value\n"
"    dir: translations                # Directory file YAML (obbligatorio)\n"
"    pattern: \"{lang}.yaml\"           # Pattern file lingua (obbligatorio)\n"
"\n"
"  markdown — Traduzione documenti Markdown\n"
"    dir: translations                # Directory root; file in translations/LANG/ (obbligatorio)\n"
"\n"
"  properties — Traduzioni Java .properties\n"
"    dir: translations                # Directory file .properties (obbligatorio)\n"
"    pattern: \"{lang}.properties\"     # Pattern file lingua (obbligatorio)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Directory file ARB (obbligatorio)\n"
"    pattern: \"app_{lang}.arb\"        # Pattern file lingua (obbligatorio)\n"
"\n"
"  js-kv — Traduzioni JavaScript key/value\n"
"    dir: translations                # Directory file JS (obbligatorio)\n"
"    pattern: \"{lang}.js\"             # Pattern file lingua (obbligatorio)\n"
"\n"
"  desktop — desktop entry freedesktop (file singolo)\n"
"    dir: .                           # Directory con file desktop\n"
"    pattern: \"myapp.desktop\"         # Nome file desktop\n"
"\n"
"  polkit — PolicyKit XML policy (file singolo)\n"
"    dir: .                           # Directory con file policy\n"
"    pattern: \"org.example.policy\"    # Nome file policy\n"
"\n"
"OPZIONI COMUNI (tutti i formati)\n"
"\n"
"  languages: [ru, de]               # Sovrascrive la lista globale delle lingue\n"
"  prompt: \"Traduzione personalizzata...\"   # Sovrascrive il prompt della traduzione AI\n"
"\n"
"ESEMPI\n"
"\n"
"  # Script shell con gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Progetto Go con funzioni wrapper\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentazione + codice\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # Applicazione web JSON\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Applicazione Flutter\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Applicazione Java con .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"

