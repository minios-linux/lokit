#: internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/yaml/properties/flutter/js-kv projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown/desktop/polkit projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      format: gettext                # Target format (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... format-specific options\n"
"\n"
"TARGET FORMATS\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — flat JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"  js-kv — JavaScript assignment key/value translations\n"
"    dir: translations                # JS files directory (required)\n"
"    pattern: \"{lang}.js\"             # Language file pattern (required)\n"
"\n"
"  desktop — freedesktop desktop entries (single file)\n"
"    dir: .                           # Directory with desktop file\n"
"    pattern: \"myapp.desktop\"         # Desktop file name\n"
"\n"
"  polkit — PolicyKit XML policy (single file)\n"
"    dir: .                           # Directory with policy file\n"
"    pattern: \"org.example.policy\"    # Policy file name\n"
"\n"
"COMMON OPTIONS (all target formats)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # JSON web application\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"
msgstr ""
"Витягує рядки для перекладу та створює/оновлює файли перекладу.\n"
"\n"
"Потрібен конфігураційний файл lokit.yaml у корені проєкту.\n"
"\n"
"Для проєктів gettext: запускає xgettext для витягу рядків у шаблон POT,\n"
"потім створює або оновлює PO-файли для кожної мови.\n"
"\n"
"Для po4a: запускає 'po4a --no-translations' для оновлення шаблонів.\n"
"\n"
"Для i18next/vue-i18n/yaml/properties/flutter/js-kv: створює відсутні мовні\n"
"файли з порожніми перекладами.\n"
"\n"
"Для android/markdown/desktop/polkit: ініціалізація не потрібна — використовуйте 'lokit translate'.\n"
"\n"
"Команда ідемпотентна — її можна запускати кілька разів. Існуючі\n"
"переклади зберігаються при оновленні файлів.\n"
"\n"
"ФОРМАТ КОНФІГУРАЦІЇ (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Мова-джерело (за замовчуванням: en)\n"
"  languages: [ru, de, fr, es, ...]   # Цільові мови\n"
"\n"
"  targets:\n"
"    - name: myproject                # Назва цілі\n"
"      format: gettext                # Формат цілі (див. нижче)\n"
"      root: .                        # Робоча директорія (за замовчуванням: .)\n"
"      # ... специфічні опції формату\n"
"\n"
"ФОРМАТИ ЦІЛЕЙ\n"
"\n"
"  gettext — Витяг рядків з коду (shell, python, C, Go тощо)\n"
"    dir: po                          # Директорія PO-файлів (обов'язково)\n"
"    pot: messages.pot                # Ім'я шаблону POT (всередині dir)\n"
"    sources: [src, scripts]          # Директорії для сканування (за замовчуванням: root)\n"
"    keywords: [_, N_, gettext]       # Ключові слова xgettext (за замовчуванням: стандартний набір)\n"
"\n"
"  po4a — Переклад документації (man-сторінки, AsciiDoc тощо)\n"
"    config: po4a.cfg                 # Шлях до po4a.cfg (обов'язково)\n"
"\n"
"  i18next — плоскі JSON-переклади\n"
"    dir: public/translations         # Директорія JSON-файлів (обов'язково)\n"
"    pattern: \"{lang}.json\"           # Шаблон імені мовного файлу (обов'язково)\n"
"\n"
"  vue-i18n — вкладені JSON-переклади\n"
"    dir: frontend/src/i18n           # Директорія JSON-файлів (обов'язково)\n"
"    pattern: \"{lang}.json\"           # Шаблон імені мовного файлу (обов'язково)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Директорія res/ Android (обов'язково)\n"
"\n"
"  yaml — YAML-переклади ключ/значення\n"
"    dir: translations                # Директорія YAML-файлів (обов'язково)\n"
"    pattern: \"{lang}.yaml\"           # Шаблон імені мовного файлу (обов'язково)\n"
"\n"
"  markdown — Переклад Markdown-документів\n"
"    dir: translations                # Коренева директорія; файли у translations/LANG/ (обов'язково)\n"
"\n"
"  properties — Java .properties-переклади\n"
"    dir: translations                # Директорія .properties-файлів (обов'язково)\n"
"    pattern: \"{lang}.properties\"     # Шаблон імені мовного файлу (обов'язково)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Директорія ARB-файлів (обов'язково)\n"
"    pattern: \"app_{lang}.arb\"        # Шаблон імені мовного файлу (обов'язково)\n"
"\n"
"  js-kv — JavaScript-переклади ключ/значення\n"
"    dir: translations                # Директорія JS-файлів (обов'язково)\n"
"    pattern: \"{lang}.js\"             # Шаблон імені мовного файлу (обов'язково)\n"
"\n"
"  desktop — freedesktop desktop entries (один файл)\n"
"    dir: .                           # Директорія з desktop-файлом\n"
"    pattern: \"myapp.desktop\"         # Назва desktop-файлу\n"
"\n"
"  polkit — PolicyKit XML policy (один файл)\n"
"    dir: .                           # Директорія з policy-файлом\n"
"    pattern: \"org.example.policy\"    # Назва policy-файлу\n"
"\n"
"ЗАГАЛЬНІ ОПЦІЇ (для всіх форматів цілей)\n"
"\n"
"  languages: [ru, de]               # Перевизначити глобальний список мов\n"
"  prompt: \"Custom translation...\"   # Перевизначити AI-підказку для перекладу\n"
"\n"
"ПРИКЛАДИ\n"
"\n"
"  # Shell-скрипти з gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go-проєкт з обгортками\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.] \n"
"      keywords: [T, N]\n"
"\n"
"  # Документація + код\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # Вебзастосунок на JSON\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter-застосунок\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java-застосунок з .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"

