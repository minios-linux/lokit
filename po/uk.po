#: /home/live/opencode/fb/lokit/internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/json/yaml/properties/flutter projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      type: gettext                  # Target type (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... type-specific options\n"
"\n"
"TARGET TYPES\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — i18next JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — vue-i18n nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  json — Simple JSON translations { \"key\": \"value\" }\n"
"    dir: translations                # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"COMMON OPTIONS (all target types)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # i18next web application\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"
msgstr ""
"Витягуйте рядки для перекладу та створюйте/оновлюйте файли перекладів.\n"
"\n"
"Потрібен конфігураційний файл lokit.yaml у корені проєкту.\n"
"\n"
"Для проєктів gettext: запускається xgettext для витягу рядків у POT-шаблон,\n"
"потім створюються або оновлюються PO-файли для кожної мови.\n"
"\n"
"Для проєктів po4a: виконується 'po4a --no-translations' для оновлення шаблонів.\n"
"\n"
"Для проєктів i18next/vue-i18n/json/yaml/properties/flutter: створюються відсутні мовні\n"
"файли з порожніми перекладами.\n"
"\n"
"Для проєктів android/markdown: ініціалізація не потрібна — використовуйте 'lokit translate'\n"
"безпосередньо.\n"
"\n"
"Ця команда ідемпотентна — її можна запускати багаторазово. Існуючі\n"
"переклади зберігаються при оновленні файлів.\n"
"\n"
"ФОРМАТ КОНФІГУ (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Мова-оригінал (за замовчуванням: en)\n"
"  languages: [ru, de, fr, es, ...]   # Цільові мови\n"
"\n"
"  targets:\n"
"    - name: myproject                # Назва цілі\n"
"      type: gettext                  # Тип цілі (див. нижче)\n"
"      root: .                        # Робочий каталог (за замовчуванням: .)\n"
"      # ... опції для типу\n"
"\n"
"ТИПИ ЦІЛЕЙ\n"
"\n"
"  gettext — Витяг рядків із коду (shell, python, C, Go тощо)\n"
"    dir: po                          # Каталог PO-файлів (обов'язково)\n"
"    pot: messages.pot                # Назва POT-шаблону (всередині dir)\n"
"    sources: [src, scripts]          # Каталоги для сканування (за замовчуванням: root)\n"
"    keywords: [_, N_, gettext]       # Ключові слова для xgettext (за замовчуванням: стандартний набір)\n"
"\n"
"  po4a — Переклад документації (man-сторінки, AsciiDoc тощо)\n"
"    config: po4a.cfg                 # Шлях до po4a.cfg (обов'язково)\n"
"\n"
"  i18next — JSON-переклади для i18next\n"
"    dir: public/translations         # Каталог JSON-файлів (обов'язково)\n"
"    pattern: \"{lang}.json\"           # Шаблон мовного файлу (обов'язково)\n"
"\n"
"  vue-i18n — Вкладені JSON-переклади для vue-i18n\n"
"    dir: frontend/src/i18n           # Каталог JSON-файлів (обов'язково)\n"
"    pattern: \"{lang}.json\"           # Шаблон мовного файлу (обов'язково)\n"
"\n"
"  json — Простий JSON-переклад { \"key\": \"value\" }\n"
"    dir: translations                # Каталог JSON-файлів (обов'язково)\n"
"    pattern: \"{lang}.json\"           # Шаблон мовного файлу (обов'язково)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Каталог res/ Android (обов'язково)\n"
"\n"
"  yaml — YAML-переклади ключ/значення\n"
"    dir: translations                # Каталог YAML-файлів (обов'язково)\n"
"    pattern: \"{lang}.yaml\"           # Шаблон мовного файлу (обов'язково)\n"
"\n"
"  markdown — Переклад Markdown-документів\n"
"    dir: translations                # Кореневий каталог; файли у translations/LANG/ (обов'язково)\n"
"\n"
"  properties — Переклади Java .properties\n"
"    dir: translations                # Каталог .properties-файлів (обов'язково)\n"
"    pattern: \"{lang}.properties\"     # Шаблон мовного файлу (обов'язково)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Каталог ARB-файлів (обов'язково)\n"
"    pattern: \"app_{lang}.arb\"        # Шаблон мовного файлу (обов'язково)\n"
"\n"
"ЗАГАЛЬНІ ОПЦІЇ (для всіх типів)\n"
"\n"
"  languages: [ru, de]               # Перевизначити глобальний список мов\n"
"  prompt: \"Custom translation...\"   # Перевизначити AI prompt для перекладу\n"
"\n"
"ПРИКЛАДИ\n"
"\n"
"  # Shell-скрипти з gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go-проєкт із обгортками\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Документація + код\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # Вебдодаток i18next\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Додаток Flutter\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java-додаток із .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"

