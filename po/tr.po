#: /home/live/opencode/fb/lokit/internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/json/yaml/properties/flutter projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      type: gettext                  # Target type (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... type-specific options\n"
"\n"
"TARGET TYPES\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — i18next JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — vue-i18n nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  json — Simple JSON translations { \"key\": \"value\" }\n"
"    dir: translations                # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"COMMON OPTIONS (all target types)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # i18next web application\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"
msgstr ""
"Çevrilebilir stringleri çıkarın ve çeviri dosyalarını oluşturun/güncelleyin.\n"
"\n"
"Proje kök dizininde bir lokit.yaml yapılandırma dosyası gereklidir.\n"
"\n"
"gettext projeleri için: xgettext çalıştırılarak stringler bir POT şablonuna çıkarılır,\n"
"sonra her dil için PO dosyaları oluşturulur veya güncellenir.\n"
"\n"
"po4a projeleri için: 'po4a --no-translations' komutu ile şablonlar güncellenir.\n"
"\n"
"i18next/vue-i18n/json/yaml/properties/flutter projeleri için: eksik dil dosyaları\n"
"boş çevirilerle oluşturulur.\n"
"\n"
"android/markdown projeleri için: başlatma adımı gerekmez — doğrudan 'lokit translate'\n"
"kullanabilirsiniz.\n"
"\n"
"Bu komut idempotenttir — birden fazla kez güvenle çalıştırılabilir. Dosyalar güncellenirken mevcut\n"
"çeviriler korunur.\n"
"\n"
"YAPILANDIRMA FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Kaynak dil (varsayılan: en)\n"
"  languages: [ru, de, fr, es, ...]   # Hedef diller\n"
"\n"
"  targets:\n"
"    - name: myproject                # Görünen adı\n"
"      type: gettext                  # Hedef tipi (aşağıya bakın)\n"
"      root: .                        # Çalışma dizini (varsayılan: .)\n"
"      # ... tipe özel seçenekler\n"
"\n"
"HEDEF TİPLERİ\n"
"\n"
"  gettext — Kaynak koddan string çıkarımı (shell, python, C, Go, vb.)\n"
"    dir: po                          # PO dosyaları dizini (zorunlu)\n"
"    pot: messages.pot                # POT şablon dosya adı (dizin içinde)\n"
"    sources: [src, scripts]          # Taranacak dizinler (varsayılan: root)\n"
"    keywords: [_, N_, gettext]       # xgettext anahtar kelimeleri (varsayılan: standart set)\n"
"\n"
"  po4a — Dokümantasyon çevirisi (man sayfaları, AsciiDoc, vb.)\n"
"    config: po4a.cfg                 # po4a.cfg dosya yolu (zorunlu)\n"
"\n"
"  i18next — i18next JSON çevirileri\n"
"    dir: public/translations         # JSON dosyaları dizini (zorunlu)\n"
"    pattern: \"{lang}.json\"           # Dil dosya deseni (zorunlu)\n"
"\n"
"  vue-i18n — vue-i18n iç içe JSON çevirileri\n"
"    dir: frontend/src/i18n           # JSON dosyaları dizini (zorunlu)\n"
"    pattern: \"{lang}.json\"           # Dil dosya deseni (zorunlu)\n"
"\n"
"  json — Basit JSON çevirileri { \"key\": \"value\" }\n"
"    dir: translations                # JSON dosyaları dizini (zorunlu)\n"
"    pattern: \"{lang}.json\"           # Dil dosya deseni (zorunlu)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ dizini (zorunlu)\n"
"\n"
"  yaml — YAML anahtar/değer çevirileri\n"
"    dir: translations                # YAML dosyaları dizini (zorunlu)\n"
"    pattern: \"{lang}.yaml\"           # Dil dosya deseni (zorunlu)\n"
"\n"
"  markdown — Markdown doküman çevirisi\n"
"    dir: translations                # Kök dizin; dosyalar translations/LANG/ altında (zorunlu)\n"
"\n"
"  properties — Java .properties çevirileri\n"
"    dir: translations                # .properties dosyaları dizini (zorunlu)\n"
"    pattern: \"{lang}.properties\"     # Dil dosya deseni (zorunlu)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB dosyaları dizini (zorunlu)\n"
"    pattern: \"app_{lang}.arb\"        # Dil dosya deseni (zorunlu)\n"
"\n"
"ORTAK SEÇENEKLER (tüm hedef tipleri)\n"
"\n"
"  languages: [ru, de]               # Global dil listesini geçersiz kılar\n"
"  prompt: \"Özel çeviri...\"          # AI çeviri promptunu geçersiz kılar\n"
"\n"
"ÖRNEKLER\n"
"\n"
"  # gettext ile shell scriptleri\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Wrapper fonksiyonlu Go projesi\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Dokümantasyon + kod\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # i18next web uygulaması\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter uygulaması\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # .properties ile Java uygulaması\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"

