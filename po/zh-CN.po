#: /home/live/opencode/fb/lokit/internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/json/yaml/properties/flutter projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      type: gettext                  # Target type (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... type-specific options\n"
"\n"
"TARGET TYPES\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — i18next JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — vue-i18n nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  json — Simple JSON translations { \"key\": \"value\" }\n"
"    dir: translations                # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"COMMON OPTIONS (all target types)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # i18next web application\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"
msgstr ""
"提取可翻译字符串并创建/更新翻译文件。\n"
"\n"
"需在项目根目录有 lokit.yaml 配置文件。\n"
"\n"
"对于 gettext 项目：运行 xgettext 提取字符串到 POT 模板，\n"
"然后为每种语言创建或更新 PO 文件。\n"
"\n"
"对于 po4a 项目：运行 'po4a --no-translations' 更新模板。\n"
"\n"
"对于 i18next/vue-i18n/json/yaml/properties/flutter 项目：\n"
"会为缺失语言文件创建空翻译。\n"
"\n"
"对于 android/markdown 项目：无需初始化，可直接用 'lokit translate'。\n"
"\n"
"本命令幂等，可多次运行。更新文件时会保留已有翻译。\n"
"\n"
"配置格式（lokit.yaml）\n"
"\n"
"  source_lang: en                    # 源语言（默认：en）\n"
"  languages: [ru, de, fr, es, ...]   # 目标语言\n"
"\n"
"  targets:\n"
"    - name: myproject                # 显示名称\n"
"      type: gettext                  # 目标类型（见下）\n"
"      root: .                        # 工作目录（默认：.）\n"
"      # ... 类型专用选项\n"
"\n"
"目标类型\n"
"\n"
"  gettext — 源代码字符串提取（shell、python、C、Go 等）\n"
"    dir: po                          # PO 文件目录（必填）\n"
"    pot: messages.pot                # POT 模板文件名（在 dir 下）\n"
"    sources: [src, scripts]          # 扫描目录（默认：root）\n"
"    keywords: [_, N_, gettext]       # xgettext 关键字（默认：标准集）\n"
"\n"
"  po4a — 文档翻译（man 手册、AsciiDoc 等）\n"
"    config: po4a.cfg                 # po4a.cfg 路径（必填）\n"
"\n"
"  i18next — i18next JSON 翻译\n"
"    dir: public/translations         # JSON 文件目录（必填）\n"
"    pattern: \"{lang}.json\"           # 语言文件模式（必填）\n"
"\n"
"  vue-i18n — vue-i18n 嵌套 JSON 翻译\n"
"    dir: frontend/src/i18n           # JSON 文件目录（必填）\n"
"    pattern: \"{lang}.json\"           # 语言文件模式（必填）\n"
"\n"
"  json — 简单 JSON 翻译 { \"key\": \"value\" }\n"
"    dir: translations                # JSON 文件目录（必填）\n"
"    pattern: \"{lang}.json\"           # 语言文件模式（必填）\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ 目录（必填）\n"
"\n"
"  yaml — YAML 键值翻译\n"
"    dir: translations                # YAML 文件目录（必填）\n"
"    pattern: \"{lang}.yaml\"           # 语言文件模式（必填）\n"
"\n"
"  markdown — Markdown 文档翻译\n"
"    dir: translations                # 根目录，文件在 translations/LANG/ 下（必填）\n"
"\n"
"  properties — Java .properties 翻译\n"
"    dir: translations                # .properties 文件目录（必填）\n"
"    pattern: \"{lang}.properties\"     # 语言文件模式（必填）\n"
"\n"
"  flutter — Flutter ARB（应用资源包）\n"
"    dir: lib/l10n                    # ARB 文件目录（必填）\n"
"    pattern: \"app_{lang}.arb\"        # 语言文件模式（必填）\n"
"\n"
"通用选项（所有目标类型）\n"
"\n"
"  languages: [ru, de]               # 覆盖全局语言列表\n"
"  prompt: \"自定义翻译...\"           # 覆盖 AI 翻译提示\n"
"\n"
"示例\n"
"\n"
"  # Shell 脚本使用 gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go 项目自定义包装函数\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # 文档 + 代码\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # i18next Web 应用\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter 应用\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java 应用 .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"

