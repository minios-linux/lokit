#: internal/cli/init.go:24
msgid ""
"Extract translatable strings and create/update translation files.\n"
"\n"
"Requires a lokit.yaml configuration file in the project root.\n"
"\n"
"For gettext projects: runs xgettext to extract strings into a POT template,\n"
"then creates or updates PO files for each language.\n"
"\n"
"For po4a projects: runs 'po4a --no-translations' to update templates.\n"
"\n"
"For i18next/vue-i18n/yaml/properties/flutter/js-kv projects: creates missing language\n"
"files with empty translations.\n"
"\n"
"For android/markdown/desktop/polkit projects: no init step needed — use 'lokit translate'\n"
"directly.\n"
"\n"
"This command is idempotent — safe to run multiple times. Existing\n"
"translations are preserved when updating files.\n"
"\n"
"CONFIG FORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Source language (default: en)\n"
"  languages: [ru, de, fr, es, ...]   # Target languages\n"
"\n"
"  targets:\n"
"    - name: myproject                # Display name\n"
"      format: gettext                # Target format (see below)\n"
"      root: .                        # Working directory (default: .)\n"
"      # ... format-specific options\n"
"\n"
"TARGET FORMATS\n"
"\n"
"  gettext — Source code string extraction (shell, python, C, Go, etc.)\n"
"    dir: po                          # PO files directory (required)\n"
"    pot: messages.pot                # POT template filename (inside dir)\n"
"    sources: [src, scripts]          # Directories to scan (default: root)\n"
"    keywords: [_, N_, gettext]       # xgettext keywords (default: standard set)\n"
"\n"
"  po4a — Documentation translation (man pages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Path to po4a.cfg (required)\n"
"\n"
"  i18next — flat JSON translations\n"
"    dir: public/translations         # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  vue-i18n — nested JSON translations\n"
"    dir: frontend/src/i18n           # JSON files directory (required)\n"
"    pattern: \"{lang}.json\"           # Language file pattern (required)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/ directory (required)\n"
"\n"
"  yaml — YAML key/value translations\n"
"    dir: translations                # YAML files directory (required)\n"
"    pattern: \"{lang}.yaml\"           # Language file pattern (required)\n"
"\n"
"  markdown — Markdown document translation\n"
"    dir: translations                # Root dir; files at translations/LANG/ (required)\n"
"\n"
"  properties — Java .properties translations\n"
"    dir: translations                # .properties files directory (required)\n"
"    pattern: \"{lang}.properties\"     # Language file pattern (required)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB files directory (required)\n"
"    pattern: \"app_{lang}.arb\"        # Language file pattern (required)\n"
"\n"
"  js-kv — JavaScript assignment key/value translations\n"
"    dir: translations                # JS files directory (required)\n"
"    pattern: \"{lang}.js\"             # Language file pattern (required)\n"
"\n"
"  desktop — freedesktop desktop entries (single file)\n"
"    dir: .                           # Directory with desktop file\n"
"    pattern: \"myapp.desktop\"         # Desktop file name\n"
"\n"
"  polkit — PolicyKit XML policy (single file)\n"
"    dir: .                           # Directory with policy file\n"
"    pattern: \"org.example.policy\"    # Policy file name\n"
"\n"
"COMMON OPTIONS (all target formats)\n"
"\n"
"  languages: [ru, de]               # Override global language list\n"
"  prompt: \"Custom translation...\"   # Override AI translation prompt\n"
"\n"
"EXAMPLES\n"
"\n"
"  # Shell scripts with gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go project with wrapper functions\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Documentation + code\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # JSON web application\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter application\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java application with .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"
msgstr ""
"Wyodrębnij frazy do tłumaczenia i utwórz/aktualizuj pliki tłumaczeń.\n"
"\n"
"Wymagany plik konfiguracyjny lokit.yaml w katalogu głównym projektu.\n"
"\n"
"Dla projektów gettext: uruchamia xgettext, aby wyodrębnić frazy do szablonu POT,\n"
"następnie tworzy lub aktualizuje pliki PO dla każdego języka.\n"
"\n"
"Dla projektów po4a: uruchamia 'po4a --no-translations', aby zaktualizować szablony.\n"
"\n"
"Dla projektów i18next/vue-i18n/yaml/properties/flutter/js-kv: tworzy brakujące pliki językowe\n"
"z pustymi tłumaczeniami.\n"
"\n"
"Dla android/markdown/desktop/polkit: inicjalizacja nie jest wymagana — użyj 'lokit translate'\n"
"bezpośrednio.\n"
"\n"
"Polecenie jest idempotentne — można uruchamiać wielokrotnie. Istniejące\n"
"tłumaczenia są zachowywane przy aktualizacji plików.\n"
"\n"
"FORMAT KONFIGURACJI (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Język źródłowy (domyślnie: en)\n"
"  languages: [ru, de, fr, es, ...]   # Języki docelowe\n"
"\n"
"  targets:\n"
"    - name: myproject                # Nazwa wyświetlana\n"
"      format: gettext                # Format docelowy (patrz niżej)\n"
"      root: .                        # Katalog roboczy (domyślnie: .)\n"
"      # ... opcje specyficzne dla formatu\n"
"\n"
"FORMATY DOCELOWE\n"
"\n"
"  gettext — Ekstrakcja fraz z kodu źródłowego (shell, python, C, Go, itd.)\n"
"    dir: po                          # Katalog plików PO (wymagany)\n"
"    pot: messages.pot                # Nazwa pliku POT (w katalogu dir)\n"
"    sources: [src, scripts]          # Katalogi do skanowania (domyślnie: root)\n"
"    keywords: [_, N_, gettext]       # Słowa kluczowe xgettext (domyślnie: standardowy zestaw)\n"
"\n"
"  po4a — Tłumaczenie dokumentacji (man, AsciiDoc, itd.)\n"
"    config: po4a.cfg                 # Ścieżka do po4a.cfg (wymagana)\n"
"\n"
"  i18next — płaskie tłumaczenia JSON\n"
"    dir: public/translations         # Katalog plików JSON (wymagany)\n"
"    pattern: \"{lang}.json\"           # Wzorzec pliku językowego (wymagany)\n"
"\n"
"  vue-i18n — zagnieżdżone tłumaczenia JSON\n"
"    dir: frontend/src/i18n           # Katalog plików JSON (wymagany)\n"
"    pattern: \"{lang}.json\"           # Wzorzec pliku językowego (wymagany)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Katalog res/ Androida (wymagany)\n"
"\n"
"  yaml — tłumaczenia YAML klucz/wartość\n"
"    dir: translations                # Katalog plików YAML (wymagany)\n"
"    pattern: \"{lang}.yaml\"           # Wzorzec pliku językowego (wymagany)\n"
"\n"
"  markdown — tłumaczenie dokumentów Markdown\n"
"    dir: translations                # Katalog główny; pliki w translations/LANG/ (wymagany)\n"
"\n"
"  properties — tłumaczenia Java .properties\n"
"    dir: translations                # Katalog plików .properties (wymagany)\n"
"    pattern: \"{lang}.properties\"     # Wzorzec pliku językowego (wymagany)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # Katalog plików ARB (wymagany)\n"
"    pattern: \"app_{lang}.arb\"        # Wzorzec pliku językowego (wymagany)\n"
"\n"
"  js-kv — tłumaczenia JavaScript klucz/wartość\n"
"    dir: translations                # Katalog plików JS (wymagany)\n"
"    pattern: \"{lang}.js\"             # Wzorzec pliku językowego (wymagany)\n"
"\n"
"  desktop — wpisy desktop freedesktop (pojedynczy plik)\n"
"    dir: .                           # Katalog z plikiem desktop\n"
"    pattern: \"myapp.desktop\"         # Nazwa pliku desktop\n"
"\n"
"  polkit — polityka PolicyKit XML (pojedynczy plik)\n"
"    dir: .                           # Katalog z plikiem polityki\n"
"    pattern: \"org.example.policy\"    # Nazwa pliku polityki\n"
"\n"
"OPCJE WSPÓLNE (wszystkie formaty docelowe)\n"
"\n"
"  languages: [ru, de]               # Nadpisuje globalną listę języków\n"
"  prompt: \"Własny prompt tłumaczenia...\"   # Nadpisuje prompt AI\n"
"\n"
"PRZYKŁADY\n"
"\n"
"  # Skrypty shell z gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Projekt Go z funkcjami wrapper\n"
"  targets:\n"
"    - name: myapp\n"
"      format: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Dokumentacja + kod\n"
"  targets:\n"
"    - name: code\n"
"      format: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      format: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # Aplikacja webowa JSON\n"
"  targets:\n"
"    - name: frontend\n"
"      format: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Aplikacja Flutter\n"
"  targets:\n"
"    - name: app\n"
"      format: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Aplikacja Java z .properties\n"
"  targets:\n"
"    - name: app\n"
"      format: properties\n"
"      dir: src/main/resources"

