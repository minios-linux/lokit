#: /home/live/opencode/fb/lokit/internal/cli/root.go:615
msgid "UI Translation Statistics"
msgstr ""
"Übersetzbare Strings extrahieren und Übersetzungsdateien erstellen/aktualisieren.\n"
"\n"
"Erfordert eine lokit.yaml-Konfigurationsdatei im Projektstamm.\n"
"\n"
"Für gettext-Projekte: Führt xgettext aus, um Strings in ein POT-Template zu extrahieren,\n"
"erstellt oder aktualisiert dann PO-Dateien für jede Sprache.\n"
"\n"
"Für po4a-Projekte: Führt 'po4a --no-translations' aus, um Templates zu aktualisieren.\n"
"\n"
"Für i18next/vue-i18n/json/yaml/properties/flutter-Projekte: Erstellt fehlende Sprachdateien\n"
"mit leeren Übersetzungen.\n"
"\n"
"Für android/markdown-Projekte: Kein Init-Schritt nötig – verwenden Sie direkt 'lokit translate'.\n"
"\n"
"Dieser Befehl ist idempotent – kann gefahrlos mehrfach ausgeführt werden. Vorhandene\n"
"Übersetzungen bleiben beim Aktualisieren erhalten.\n"
"\n"
"KONFIGURATIONSFORMAT (lokit.yaml)\n"
"\n"
"  source_lang: en                    # Quellsprache (Standard: en)\n"
"  languages: [ru, de, fr, es, ...]   # Zielsprachen\n"
"\n"
"  targets:\n"
"    - name: myproject                # Anzeigename\n"
"      type: gettext                  # Zieltyp (siehe unten)\n"
"      root: .                        # Arbeitsverzeichnis (Standard: .)\n"
"      # ... Typspezifische Optionen\n"
"\n"
"ZIELTYPEN\n"
"\n"
"  gettext — Quellcode-String-Extraktion (Shell, Python, C, Go, etc.)\n"
"    dir: po                          # PO-Dateien-Verzeichnis (erforderlich)\n"
"    pot: messages.pot                # POT-Template-Dateiname (im Verzeichnis)\n"
"    sources: [src, scripts]          # Zu scannende Verzeichnisse (Standard: root)\n"
"    keywords: [_, N_, gettext]       # xgettext-Schlüsselwörter (Standard: Standardset)\n"
"\n"
"  po4a — Dokumentationsübersetzung (Manpages, AsciiDoc, etc.)\n"
"    config: po4a.cfg                 # Pfad zu po4a.cfg (erforderlich)\n"
"\n"
"  i18next — i18next JSON-Übersetzungen\n"
"    dir: public/translations         # JSON-Dateien-Verzeichnis (erforderlich)\n"
"    pattern: \"{lang}.json\"           # Sprachdateimuster (erforderlich)\n"
"\n"
"  vue-i18n — vue-i18n verschachtelte JSON-Übersetzungen\n"
"    dir: frontend/src/i18n           # JSON-Dateien-Verzeichnis (erforderlich)\n"
"    pattern: \"{lang}.json\"           # Sprachdateimuster (erforderlich)\n"
"\n"
"  json — Einfache JSON-Übersetzungen { \"key\": \"value\" }\n"
"    dir: translations                # JSON-Dateien-Verzeichnis (erforderlich)\n"
"    pattern: \"{lang}.json\"           # Sprachdateimuster (erforderlich)\n"
"\n"
"  android — Android strings.xml\n"
"    dir: app/src/main/res            # Android res/-Verzeichnis (erforderlich)\n"
"\n"
"  yaml — YAML-Key/Value-Übersetzungen\n"
"    dir: translations                # YAML-Dateien-Verzeichnis (erforderlich)\n"
"    pattern: \"{lang}.yaml\"           # Sprachdateimuster (erforderlich)\n"
"\n"
"  markdown — Markdown-Dokumentübersetzung\n"
"    dir: translations                # Root-Verzeichnis; Dateien unter translations/LANG/ (erforderlich)\n"
"\n"
"  properties — Java .properties-Übersetzungen\n"
"    dir: translations                # .properties-Dateien-Verzeichnis (erforderlich)\n"
"    pattern: \"{lang}.properties\"     # Sprachdateimuster (erforderlich)\n"
"\n"
"  flutter — Flutter ARB (Application Resource Bundle)\n"
"    dir: lib/l10n                    # ARB-Dateien-Verzeichnis (erforderlich)\n"
"    pattern: \"app_{lang}.arb\"        # Sprachdateimuster (erforderlich)\n"
"\n"
"GEMEINSAME OPTIONEN (alle Zieltypen)\n"
"\n"
"  languages: [ru, de]               # Globale Sprachliste überschreiben\n"
"  prompt: \"Benutzerdefinierte Übersetzung...\"   # KI-Übersetzungsprompt überschreiben\n"
"\n"
"BEISPIELE\n"
"\n"
"  # Shell-Skripte mit gettext\n"
"  source_lang: en\n"
"  languages: [ru, de, fr]\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [scripts, lib]\n"
"      keywords: [gettext, eval_gettext]\n"
"\n"
"  # Go-Projekt mit Wrapper-Funktionen\n"
"  targets:\n"
"    - name: myapp\n"
"      type: gettext\n"
"      sources: [.]\n"
"      keywords: [T, N]\n"
"\n"
"  # Dokumentation + Code\n"
"  targets:\n"
"    - name: code\n"
"      type: gettext\n"
"      sources: [src]\n"
"    - name: docs\n"
"      type: po4a\n"
"      config: docs/po4a.cfg\n"
"\n"
"  # i18next-Webanwendung\n"
"  targets:\n"
"    - name: frontend\n"
"      type: i18next\n"
"      dir: public/translations\n"
"\n"
"  # Flutter-Anwendung\n"
"  targets:\n"
"    - name: app\n"
"      type: flutter\n"
"      dir: lib/l10n\n"
"\n"
"  # Java-Anwendung mit .properties\n"
"  targets:\n"
"    - name: app\n"
"      type: properties\n"
"      dir: src/main/resources"

