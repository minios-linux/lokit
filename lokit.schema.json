{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/minios-linux/lokit/refs/heads/master/lokit.schema.json",
  "title": "lokit.yaml",
  "description": "Configuration file for lokit.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source_lang": {
      "type": "string",
      "default": "en",
      "description": "Source language code (BCP 47)."
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Default target language list inherited by targets."
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "description": "Translation targets.",
      "items": {
        "$ref": "#/$defs/target"
      }
    }
  },
  "required": [
    "targets"
  ],
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "model"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "google",
            "gemini",
            "groq",
            "opencode",
            "copilot",
            "ollama",
            "custom-openai"
          ],
          "description": "Default provider id for translate command."
        },
        "model": {
          "type": "string",
          "description": "Default model for translate command."
        },
        "base_url": {
          "type": "string",
          "description": "Optional endpoint URL (custom-openai or ollama only)."
        },
        "prompt": {
          "type": "string",
          "description": "Optional global prompt used when --prompt is not set."
        },
        "settings": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2,
              "description": "Model temperature override."
            }
          }
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Target name (must be unique)."
        },
        "type": {
          "type": "string",
          "enum": [
            "gettext",
            "po4a",
            "i18next",
            "vue-i18n",
            "json",
            "android",
            "yaml",
            "markdown",
            "properties",
            "flutter"
          ],
          "description": "Translation format type."
        },
        "root": {
          "type": "string",
          "default": ".",
          "description": "Base directory for all target paths, relative to lokit.yaml."
        },
        "dir": {
          "type": "string",
          "description": "Directory containing translation files (relative to root)."
        },
        "pattern": {
          "type": "string",
          "description": "File pattern relative to dir for language-based files. Must contain {lang}."
        },
        "pot": {
          "type": "string",
          "description": "POT file name relative to dir (gettext only)."
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Source directories/files to scan (gettext only)."
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "xgettext keywords (gettext only)."
        },
        "config": {
          "type": "string",
          "description": "Path to po4a.cfg relative to root (po4a only)."
        },
        "source_lang": {
          "type": "string",
          "description": "Source language override for this target."
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Target language override for this target."
        },
        "prompt": {
          "type": "string",
          "description": "Custom prompt override for this target."
        },
        "locked_keys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Keys whose existing translations are preserved (skipped unless --force)."
        },
        "ignored_keys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Keys excluded from translation entirely."
        },
        "locked_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "regex"
          },
          "description": "Regex patterns for keys treated as locked (skipped unless --force)."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "gettext"
              }
            }
          },
          "then": {
            "required": [
              "dir",
              "pot"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "po4a"
              }
            }
          },
          "then": {
            "required": [
              "config"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "i18next",
                  "vue-i18n",
                  "json",
                  "yaml",
                  "properties",
                  "flutter"
                ]
              }
            }
          },
          "then": {
            "required": [
              "dir",
              "pattern"
            ],
            "properties": {
              "pattern": {
                "pattern": "\\{lang\\}"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "android",
                  "markdown"
                ]
              }
            }
          },
          "then": {
            "required": [
              "dir"
            ]
          }
        }
      ]
    }
  }
}
