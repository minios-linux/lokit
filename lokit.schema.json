{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/minios-linux/lokit/refs/heads/master/lokit.schema.json",
  "title": "lokit.yaml",
  "description": "Configuration file for lokit.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source_lang": {
      "type": "string",
      "default": "en",
      "description": "Source language code (BCP 47)."
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Default target language list inherited by targets."
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "description": "Translation targets.",
      "items": {
        "$ref": "#/$defs/target"
      }
    }
  },
  "required": [
    "targets"
  ],
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "model"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "google",
            "gemini",
            "groq",
            "opencode",
            "copilot",
            "openai",
            "ollama",
            "custom-openai"
          ],
          "description": "Default provider id for translate command."
        },
        "model": {
          "type": "string",
          "description": "Default model for translate command."
        },
        "base_url": {
          "type": "string",
          "description": "Optional endpoint URL (custom-openai or ollama)."
        },
        "prompt": {
          "type": "string",
          "description": "Optional global prompt used when --prompt is not set."
        },
        "settings": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2,
              "description": "Model temperature override."
            }
          }
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Target name (must be unique)."
        },
        "format": {
          "type": "string",
          "enum": [
            "gettext",
            "po4a",
            "i18next",
            "vue-i18n",
            "android",
            "yaml",
            "markdown",
            "properties",
            "flutter",
            "js-kv",
            "desktop",
            "polkit"
          ],
          "description": "Translation format."
        },
        "root": {
          "type": "string",
          "default": ".",
          "description": "Base directory for all target paths, relative to lokit.yaml."
        },
        "dir": {
          "type": "string",
          "description": "Directory containing translation files (relative to root)."
        },
        "pattern": {
          "type": "string",
          "description": "File pattern relative to dir for language-based files. Must contain {lang}."
        },
        "source": {
          "oneOf": [
            {
              "type": "string",
              "description": "Source file path pattern relative to root."
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "index",
                "key_field",
                "fields"
              ],
              "properties": {
                "index": {
                  "type": "string",
                  "description": "Path to index file relative to root."
                },
                "records_path": {
                  "type": "string",
                  "default": "$",
                  "description": "Record array selector. Supported: '$' or '$.field'."
                },
                "key_field": {
                  "type": "string",
                  "description": "Record field used to fill {id} in target paths."
                },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "minItems": 1,
                  "description": "Translatable fields extracted from each record."
                }
              },
              "description": "Index source configuration for one-file source catalogs."
            }
          ]
        },
        "target": {
          "type": "string",
          "description": "Target file path pattern relative to root."
        },
        "pot": {
          "type": "string",
          "description": "POT file name relative to dir (gettext only)."
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Source directories/files to scan (gettext only)."
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "xgettext keywords (gettext only)."
        },
        "config": {
          "type": "string",
          "description": "Path to po4a.cfg relative to root (po4a only)."
        },
        "source_lang": {
          "type": "string",
          "description": "Source language override for this target."
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Target language override for this target."
        },
        "prompt": {
          "type": "string",
          "description": "Custom prompt override for this target."
        },
        "locked_keys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Keys whose existing translations are preserved (skipped unless --force)."
        },
        "ignored_keys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Keys excluded from translation entirely."
        },
        "locked_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "regex"
          },
          "description": "Regex patterns for keys treated as locked (skipped unless --force)."
        },
        "surfaces": {
          "type": "array",
          "description": "Optional list of per-surface configs inheriting from target defaults.",
          "items": {
            "$ref": "#/$defs/target"
          }
        }
      }
    }
  }
}
